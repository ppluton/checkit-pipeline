GUARDIAN_API_KEY=your_guardian_api_key_here
# Optional. Unset, the pipeline reads the bundled sample
# (data/samples/fakeddit_multimodal_sample.tsv). Point this at the real
# ~1M-row multimodal_train.tsv to extract Fakeddit at scale.
# FAKEDDIT_TSV_PATH=/absolute/path/to/multimodal_train.tsv

# Postgres (docker-compose). Airflow metadata role + least-privilege app role
# used by the load_to_postgres task. Defaults below match docker-compose.yml.
POSTGRES_USER=airflow
POSTGRES_PASSWORD=change_me
POSTGRES_DB=airflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
CHECKIT_DB=checkit
CHECKIT_APP_USER=checkit_app
CHECKIT_APP_PASSWORD=change_me
# Cloud variant (e.g. Neon): set the full URL and skip the parts above.
# CHECKIT_DB_URL=postgresql+psycopg2://user:pass@ep-xxx.neon.tech/checkit?sslmode=require
